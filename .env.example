# Copy to `.env` and adjust. `.env` is gitignored.
# Loaded by src/config.ts via dotenv at startup of every composition root.

# --- Persistence ----------------------------------------------------------

# Path to the JSON file used by JsonFileUserRepository.
# Default: ./.data/users.json
USERS_DATA_FILE=

# Path to the JSON file used by JsonFileOrderRepository.
# Default: ./.data/orders.json
ORDERS_DATA_FILE=

# --- HTTP -----------------------------------------------------------------

# HTTP server port for `npm run serve`. Must be an integer in 1..65535.
# Default: 3000
PORT=

# --- Runtime --------------------------------------------------------------

# Runtime environment. One of: development | production | test
# Default: development
NODE_ENV=

# --- Cross-cutting --------------------------------------------------------

# Per-key rate limit (1-minute fixed window). Used by
# RateLimitedCreateUser (§4.5).
# Default: 60
RATE_LIMIT_PER_MINUTE=

# Comma-separated feature flags. Recognized today:
#   cache-users — wrap UserRepository with CachedUserRepository (§6.12)
ENABLED_FEATURES=
